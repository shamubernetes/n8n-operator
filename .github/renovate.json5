{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:best-practices',
    'docker:enableMajor',
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/(^|/)Makefile$/',
      ],
      matchStrings: [
        'GOLANGCI_LINT_VERSION \\?= (?<currentValue>v\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'golangci/golangci-lint',
      datasourceTemplate: 'github-releases',
    },
  ],
  // Disable digest pinning — github-releases datasource (used by Makefile custom manager
  // for golangci-lint) can't resolve commit digests, causing pin-dependencies to fail.
  // pinDigests in packageRules doesn't work (evaluated before updateType is decided).
  pinDigests: false,
  enabled: true,
  configWarningReuseIssue: true,
  configMigration: true,
  osvVulnerabilityAlerts: true,
}
