{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:best-practices',
    'docker:enableMajor',
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/(^|/)Makefile$/',
      ],
      matchStrings: [
        'GOLANGCI_LINT_VERSION \\?= (?<currentValue>v\\d+\\.\\d+\\.\\d+)',
      ],
      depNameTemplate: 'golangci/golangci-lint',
      datasourceTemplate: 'github-releases',
    },
  ],
  packageRules: [
    {
      // golangci-lint in Makefile is a Go install via custom regex manager.
      // github-releases datasource can't resolve commit digests — disable pinning.
      matchDepNames: ['golangci/golangci-lint'],
      matchFileNames: ['Makefile'],
      pinDigests: false,
    },
  ],
  enabled: true,
  configWarningReuseIssue: true,
  configMigration: true,
  osvVulnerabilityAlerts: true,
}
